# =====================================================
# 환경 변수 템플릿
# 이 파일을 복사해서 ".env" 로 만든 뒤 비밀번호를 채우세요.
# .env 파일은 절대 git 에 커밋하지 마세요.
# =====================================================

# Supabase Postgres 연결 문자열
# 위치: Supabase 대시보드 → Project Settings → Database → Connection string → URI
#
# ⚠️ 비밀번호에 특수문자(@, #, $, /, ? 등)가 있으면 반드시 URL 인코딩하세요.
#   예) "myPass#1" → "myPass%231"  (# 은 %23)
#
# 형식:
DATABASE_URL=postgresql://postgres:비밀번호URL인코딩@db.<your-project-ref>.supabase.co:5432/postgres

# 로컬 서버 포트 (선택)
PORT=3000
